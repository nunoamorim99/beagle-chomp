{
  "name": "beagle-chomp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A responsive, installable (PWA) maze-chase game built with three.js.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-maze.ts",
    "sim": "tsx scripts/sim-logic.ts",
    "test": "npm run validate && npm run sim"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.169.0",
    "playwright": "^1.61.1",
    "tsx": "^4.22.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5"
  }
}
